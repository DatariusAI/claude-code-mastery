# HealthTrack API — local environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env` (gitignored) and fill in real-but-local values.
# NEVER commit a real .env. NEVER paste production credentials here.
# ----------------------------------------------------------------------------

# Flask runtime
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Postgres (matches docker-compose service name `db`)
DB_HOST=db
DB_PORT=5432
DB_NAME=healthtrack
DB_USER=healthtrack
DB_PASSWORD=change-me-locally

# Redis (matches docker-compose service name `cache`)
REDIS_URL=redis://cache:6379/0

# Anthropic — only the CI Skill Review job actually consumes this. Local
# `compose up` works fine with this placeholder; do not paste a real key.
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
