#!/bin/sh
# ============================================================
# Pre-commit hook — Week 7 capstone governance gate
# Adapted from week-7/capstone-py/.hooks/pre-commit
# ============================================================

# Only run capstone gates when files in week-7/capstone-py/ are staged
if ! git diff --cached --name-only | grep -q "^week-7/capstone-py/"; then
  exit 0
fi

echo "Running Week 7 capstone pre-commit governance checks..."

cd week-7/capstone-py || exit 1

# 1. Lint
echo "  [1/3] flake8 lint..."
if [ -d venv ]; then
  ./venv/Scripts/flake8.exe src/ tests/ 2>/dev/null \
    || ./venv/bin/flake8 src/ tests/ 2>/dev/null \
    || flake8 src/ tests/
else
  flake8 src/ tests/
fi
LINT_RESULT=$?
if [ $LINT_RESULT -ne 0 ]; then
  echo "  COMMIT BLOCKED: flake8 errors. Fix before committing."
  exit 1
fi
echo "  Lint passed"

# 2. Unit tests
echo "  [2/3] pytest unit tests..."
if [ -d venv ]; then
  EMAIL_PROVIDER=mock ./venv/Scripts/pytest.exe tests/unit/ -q --no-header --no-cov 2>/dev/null \
    || EMAIL_PROVIDER=mock ./venv/bin/pytest tests/unit/ -q --no-header --no-cov 2>/dev/null \
    || EMAIL_PROVIDER=mock pytest tests/unit/ -q --no-header --no-cov
else
  EMAIL_PROVIDER=mock pytest tests/unit/ -q --no-header --no-cov
fi
TEST_RESULT=$?
if [ $TEST_RESULT -ne 0 ]; then
  echo "  COMMIT BLOCKED: Unit tests failed."
  exit 1
fi
echo "  Unit tests passed"

# 3. Audit log entry
echo "  [3/3] Writing governance audit entry..."
AUDIT_FILE=".audit-log.jsonl"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
STAGED=$(git diff --cached --name-only | tr '\n' ',' | sed 's/,$//')
USER=$(git config user.email 2>/dev/null || echo "unknown")

echo "{\"timestamp\":\"$TIMESTAMP\",\"event\":\"pre-commit\",\"branch\":\"$BRANCH\",\"user\":\"$USER\",\"staged_files\":\"$STAGED\",\"status\":\"approved\"}" >> "$AUDIT_FILE"
echo "  Audit entry written to week-7/capstone-py/$AUDIT_FILE"

echo ""
echo "All Week 7 governance checks passed — commit approved."
