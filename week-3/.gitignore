# Override root .gitignore: track .claude/ for this project
# (slash commands, hooks, settings, and audit samples are deliverables)
!.claude/

# Ignore copied source files in sample-target (only curated demos committed)
sample-target/src/
sample-target/node_modules/
sample-target/dist/
sample-target/.env
sample-target/package.json
sample-target/package-lock.json
sample-target/tsconfig.json
sample-target/vitest.config.ts
sample-target/tests/
# But track the curated demo test file
!sample-target/tests/shorten.test.ts
