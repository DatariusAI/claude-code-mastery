# FinTrack MCP Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# GitHub Personal Access Token — read-only scopes: Issues, PRs, Contents, Metadata
FINTRACK_GITHUB_TOKEN=ghp_your_token_here

# PostgreSQL read-only connection string (provided by instructor for lab)
FINTRACK_PG_READ_URL=postgresql://readonly:password@localhost:5432/fintrack_analytics

# Jira API token (optional — needed for Sprint Health workflow)
FINTRACK_JIRA_TOKEN=your_jira_api_token_here
FINTRACK_JIRA_BASE_URL=https://fintrack.atlassian.net

# Slack incoming webhook URL (optional — needed for Slack posting)
FINTRACK_SLACK_WEBHOOK=https://hooks.slack.com/services/your/webhook/url

# GitHub repository to query (format: owner/repo)
FINTRACK_GITHUB_REPO=instructor/fintrack-backend-lab

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514
